# Required
TELEGRAM_BOT_TOKEN=
OCTOPUS_API_KEY=

# Optional — override any of these
# DEFAULT_REGION=C
# DATABASE_PATH=/data/bot.db
# LOG_LEVEL=info        # debug | info | warn | error
# LOG_FORMAT=json       # json | text
# TZ=Europe/London
# ALLOWED_CHAT_IDS=     # comma-separated int64 list; empty means public

# --- Web UI (optional; HTTP API disabled if SESSION_SECRET is unset) ---
# HTTP_LISTEN_ADDR=:8080
# WEB_BASE_URL=http://localhost:8080   # public URL; set to https://... for cookie security
# SESSION_SECRET=                      # ≥ 16 bytes of random
# ENCRYPTION_KEY=                      # exactly 32 bytes (AES-256-GCM) — required to link an Octopus account
